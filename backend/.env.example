# LCUMod Backend Configuration

# Mod TCP wire protocol host/port
MOD_HOST=127.0.0.1
MOD_PORT=25568

# Backend web dashboard port
WEB_PORT=8080

# LLM API — Xiaomi MiMo (默认服务商)
# ─── Token Plan (订阅制) ───
# Key格式: tp-xxxxx
# 从 https://platform.xiaomimimo.com 订阅后获取
# Base URL: https://token-plan-cn.xiaomimimo.com/v1 (中国)
#           https://token-plan-sgp.xiaomimimo.com/v1 (新加坡)
#           https://token-plan-ams.xiaomimimo.com/v1 (欧洲)
# ─── 按量付费 ───
# Key格式: sk-xxxxx
# Base URL 不同，见官网文档
MIMO_API_KEY=
LLM_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
LLM_MODEL=mimo-v2.5-pro
LLM_TEMPERATURE=1.0

# Agent identity / persona
AI_NAME=AIBot
AI_PERSONA_FILE=persona.yml

# Token tracking
TOKEN_LOG_FILE=token_usage.csv
