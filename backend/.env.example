# LCUMod Backend Configuration

# Mod TCP wire protocol host/port
MOD_HOST=127.0.0.1
MOD_PORT=25568
# Must match wireToken in the NeoForge lcumod config. Empty is loopback-only development mode.
MOD_WIRE_TOKEN=

# Backend web dashboard port
WEB_HOST=127.0.0.1
WEB_PORT=8080

# Required when WEB_HOST is not localhost/loopback
SDK_API_TOKEN=

# Exact browser origins allowed to call the SDK, comma-separated
# SDK_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
SDK_ALLOWED_ORIGINS=

# Stable companion identity and memory isolation
# COMPANION_ID=generated-and-persisted-by-default
MEMORY_SCOPE=global
SERVER_ID=default
WORLD_ID=default

# LLM API — Xiaomi MiMo (默认服务商)
# ─── Token Plan (订阅制) ───
# Key格式: tp-xxxxx
# 从 https://platform.xiaomimimo.com 订阅后获取
# Base URL: https://token-plan-cn.xiaomimimo.com/v1 (中国)
#           https://token-plan-sgp.xiaomimimo.com/v1 (新加坡)
#           https://token-plan-ams.xiaomimimo.com/v1 (欧洲)
# ─── 按量付费 ───
# Key格式: sk-xxxxx
# Base URL 不同，见官网文档
MIMO_API_KEY=
LLM_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
LLM_MODEL=mimo-v2.5-pro
LLM_TEMPERATURE=1.0

# Agent identity / persona
AI_NAME=AIBot
AI_PERSONA_FILE=persona.yml

# Token tracking
TOKEN_LOG_FILE=token_usage.csv
